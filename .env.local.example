# LI.FI Composer API key — required for live cross-chain quotes on /calculator.
# Get one at https://docs.li.fi/integrate-li.fi-js-sdk/install-li.fi-sdk#api-key
# Without this, /api/quote will return 500 and the calculator falls back to
# static gas/bridge estimates.
LIFI_API_KEY=

# WalletConnect project ID — used by RainbowKit for wallet connection.
# Get one at https://cloud.reown.com (formerly WalletConnect Cloud).
# If unset, providers.tsx falls back to a public dev id.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
